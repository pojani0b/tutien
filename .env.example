# ============================================================
# HONG HOANG TEXT RPG — ENVIRONMENT VARIABLES
# Copy this file to .env in the server/ directory
# NEVER commit .env to version control
# ============================================================

# ---- Supabase ----
# Your Supabase project URL (public, safe in server)
SUPABASE_URL=https://xxxx.supabase.co
# Service role key — KEEP SECRET, backend only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Google Gemini Fallback Key ----
# Used only if apisv table is empty or all keys exhausted
GEMINI_API_KEY=AIza...

# ---- JWT ----
# Strong random string, min 32 chars
JWT_SECRET=change_me_to_a_random_64_char_string

# ---- Server ----
PORT=3001
NODE_ENV=development

# ============================================================
# CLIENT (Vite) — these are public, embedded in the browser bundle
# Only put NON-SECRET values here
# ============================================================
VITE_API_BASE_URL=http://localhost:3001
VITE_SUPABASE_URL=https://xxxx.supabase.co
# Anon/public key — read-only, no service-role privileges
# Used ONLY for Supabase Realtime subscriptions on the client
VITE_SUPABASE_ANON_KEY=eyJ...
